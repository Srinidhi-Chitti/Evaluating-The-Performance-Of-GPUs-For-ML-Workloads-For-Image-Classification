import pickle
import jax
import jax.numpy as jnp
import jax.profiler
import tensorflow_datasets as tfds
import tensorflow as tf
from jax import lax

from src.models.cnn import CNN

# ------------------------------
# SYSTEM SETUP
# ------------------------------
tf.config.set_visible_devices([], "GPU")

print("JAX backend:", jax.default_backend())
print("Devices:", jax.devices())

# ------------------------------
# STATIC KERNELS
# ------------------------------
BLUR_KERNEL = jnp.array([
    [1, 2, 1],
    [2, 4, 2],
    [1, 2, 1]
]) / 16.0

SOBEL_X = jnp.array([
    [-1, 0, 1],
    [-2, 0, 2],
    [-1, 0, 1]
])

def prepare_kernels():
    blur = BLUR_KERNEL[:, :, None, None]
    blur = jnp.repeat(blur, 3, axis=2)   # (3,3,3,1)

    sobel = SOBEL_X[:, :, None, None]
    sobel = jnp.repeat(sobel, 3, axis=2)

    return blur, sobel

BLUR_K, SOBEL_K = prepare_kernels()

# ------------------------------
# DATA LOADER
# ------------------------------
def load_cifar10(batch_size=64):
    ds = tfds.load("cifar10", split="test[:5%]", as_supervised=True)

    def preprocess(x, y):
        x = tf.cast(x, tf.float32)
        return x, y

    ds = ds.map(preprocess, num_parallel_calls=tf.data.AUTOTUNE)
    ds = ds.batch(batch_size)
    ds = ds.prefetch(tf.data.AUTOTUNE)

    return tfds.as_numpy(ds)

# ------------------------------
# FULL OPTIMIZED PIPELINE
# ------------------------------
@jax.jit(donate_argnums=(1,))
def full_pipeline(variables, images, model):

    # Normalize
    images = images / 255.0

    # Blur
    images = lax.conv_general_dilated(
        images,
        BLUR_K,
        (1, 1),
        "SAME",
        dimension_numbers=("NHWC", "HWIO", "NHWC")
    )

    # Edge Detection
    edges = lax.conv_general_dilated(
        images,
        SOBEL_K,
        (1, 1),
        "SAME",
        dimension_numbers=("NHWC", "HWIO", "NHWC")
    )

    # CNN
    logits = model.apply(variables, edges)

    return jax.nn.softmax(logits)

# ------------------------------
# MAIN FUNCTION
# ------------------------------
def run():
    print("\n--- OPTIMIZED PIPELINE PROFILING ---")

    # Model init
    model = CNN(num_classes=10)

    dummy = jnp.ones((1, 32, 32, 3))
    _ = model.init(jax.random.PRNGKey(0), dummy)

    # Load trained params
    with open("cnn_cifar10_params.pkl", "rb") as f:
        loaded = pickle.load(f)

    variables = loaded if "params" in loaded else {"params": loaded}

    # Load dataset
    dataset = load_cifar10()

    # ------------------------------
    # WARMUP
    # ------------------------------
    print("Warming up...")
    for i, (images, _) in enumerate(dataset):
        images = jax.device_put(images)   # FIXED
        full_pipeline(variables, images, model).block_until_ready()
        if i == 2:
            break

    # ------------------------------
    # PROFILING
    # ------------------------------
    jax.profiler.start_trace("/tmp/profile-data")
    print("Profiling started...")

    for images, _ in dataset:
        with jax.profiler.TraceAnnotation("full_pipeline"):
            images = jax.device_put(images)   # FIXED
            preds = full_pipeline(variables, images, model)
            preds.block_until_ready()

    jax.profiler.stop_trace()

    print("✅ Profiling complete!")
    print("👉 Run this in terminal:")
    print("xprof --port 8791 /tmp/profile-data")

# ------------------------------
if __name__ == "__main__":
    run()


